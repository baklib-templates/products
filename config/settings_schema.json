        "rows": 10,
        "placeholder": "t:schema.custom_html.settings.head_html.placeholder"
      },
      {
        "id": "header_menu_html",
        "type": "html",
        "label": "t:schema.custom_html.settings.header_menu_html.label",
        "info": "t:schema.custom_html.settings.header_menu_html.info",
        "rows": 6,
        "placeholder": "t:schema.custom_html.settings.header_menu_html.placeholder"
      },
      {
        "id": "footer_menu_html",
        "type": "html",
        "label": "t:schema.custom_html.settings.footer_menu_html.label",
        "info": "t:schema.custom_html.settings.footer_menu_html.info",
        "rows": 6,
        "placeholder": "t:schema.custom_html.settings.footer_menu_html.placeholder"
      }
    ]
  },
  {
    "name": "t:schema.settings.weixin_share.title",
    "settings": [
      {
