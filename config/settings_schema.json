[
  {
    "name": "theme_info",
    "theme_name": "products",
    "theme_label": "product hub",
    "theme_description": "B2B product catalog hub. An online, searchable product dictionary anchored on each product: model code, taxonomy (series / industries / scenarios), spec groups, hero image and rich content. Rational industrial style, teal brand, no e-commerce.",
    "theme_version": "1.0.0",
    "theme_syntax_version": "v2",
    "theme_scope": "cms",
    "theme_author": "Baklib",
    "theme_documentation_url": "https://help.baklib.cn/",
    "theme_support_url": "https://help.baklib.cn/",
    "theme_thumb_url": "images/theme/thumb.png",
    "theme_preview_images": [
      "images/theme/release-guide.png",
      "images/theme/index-card.png",
      "images/theme/page.png"
    ],
    "theme_languages": [
      { "name": "中文简体", "value": "zh-CN" },
      { "name": "中文繁體", "value": "zh-TW" },
      { "name": "한국어", "value": "ko" },
      { "name": "English", "value": "en" },
      { "name": "日本語", "value": "ja" }
    ],
    "recommendations": {
      "color_schemas": {
        "baklib": {
          "name": "Baklib",
          "colors": {
            "--theme-color-primary": "#0f766e",
            "--theme-color-secondary": "#c2410c",
            "--theme-color-accent": "#0f172a",
            "--theme-color-info": "#38bdf8",
            "--theme-color-success": "#14b8a6",
            "--theme-color-warning": "#fb923c"
          }
        },
        "industrial_teal": {
          "name": "Industrial Teal",
          "colors": {
            "--theme-color-primary": "#0d9488",
            "--theme-color-secondary": "#0f172a",
            "--theme-color-accent": "#64748b",
            "--theme-color-info": "#0284c7",
            "--theme-color-success": "#16a34a",
            "--theme-color-warning": "#d97706"
          }
        },
        "graphite": {
          "name": "Graphite",
          "colors": {
            "--theme-color-primary": "#1e293b",
            "--theme-color-secondary": "#0d9488",
            "--theme-color-accent": "#94a3b8",
            "--theme-color-info": "#0ea5e9",
            "--theme-color-success": "#22c55e",
            "--theme-color-warning": "#f59e0b"
          }
        },
        "deep_ocean": {
          "name": "Deep Ocean",
          "colors": {
            "--theme-color-primary": "#0369a1",
            "--theme-color-secondary": "#0f172a",
            "--theme-color-accent": "#64748b",
            "--theme-color-info": "#06b6d4",
            "--theme-color-success": "#16a34a",
            "--theme-color-warning": "#ea580c"
          }
        }
      }
    }
  },
  {
    "name": "t:schema.generic.name",
    "settings": [
      {
        "id": "slogan",
        "type": "text",
        "label": "t:schema.generic.settings.slogan.label",
        "default": "t:schema.generic.settings.slogan.default"
      },
      {
        "id": "logo_url",
        "type": "image_picker",
        "label": "t:schema.generic.settings.logo_url.label",
        "info": "t:schema.generic.settings.logo_url.info"
      },
      {
        "id": "company_name",
        "label": "t:schema.generic.settings.company_name.label",
        "type": "text",
        "default": "t:schema.generic.settings.company_name.default",
        "info": "t:schema.generic.settings.company_name.info"
      },
      {
        "id": "is_allow_feedback",
        "type": "checkbox",
        "label": "t:schema.generic.settings.is_allow_feedback.label",
        "default": true
      },
      {
        "id": "is_allow_header",
        "type": "checkbox",
        "label": "t:schema.generic.settings.is_allow_header.label",
        "default": true
      },
      {
        "id": "is_allow_footer",
        "type": "checkbox",
        "label": "t:schema.generic.settings.is_allow_footer.label",
        "default": true
      }
    ]
  },
  {
    "name": "t:schema.taxonomy.name",
    "settings": [
      {
        "id": "industries",
        "type": "textarea",
        "label": "t:schema.taxonomy.settings.industries.label",
        "info": "t:schema.taxonomy.settings.industries.info",
        "rows": 6,
        "default": "Industrial Automation\nMedical Devices\nEnergy & Power\nRobotics\nElectronics Manufacturing\nLogistics & Warehousing"
      },
      {
        "id": "scenarios",
        "type": "textarea",
        "label": "t:schema.taxonomy.settings.scenarios.label",
        "info": "t:schema.taxonomy.settings.scenarios.info",
        "rows": 6,
        "default": "Production Line Integration\nQuality Inspection\nOutdoor Deployment\nCleanroom Operation\nHazardous Environment\nRemote Monitoring"
      },
      {
        "id": "series",
        "type": "textarea",
        "label": "t:schema.taxonomy.settings.series.label",
        "info": "t:schema.taxonomy.settings.series.info",
        "rows": 5,
        "default": "X Series\nS Series\nPro Series\nCompact Series"
      }
    ]
  },
  {
    "name": "t:schema.hub.name",
    "settings": [
      {
        "id": "cta_quote_label",
        "type": "text",
        "label": "t:schema.hub.settings.cta_quote_label.label",
        "info": "t:schema.hub.settings.cta_quote_label.info",
        "default": "t:schema.hub.settings.cta_quote_label.default"
      },
      {
        "id": "cta_quote_url",
        "type": "text",
        "label": "t:schema.hub.settings.cta_quote_url.label",
        "info": "t:schema.hub.settings.cta_quote_url.info",
        "default": "/s/quote",
        "placeholder": "/s/quote"
      }
    ]
  },
  {
    "name": "t:schema.custom_html.name",
    "settings": [
      {
        "id": "head_html",
        "type": "html",
        "label": "t:schema.custom_html.settings.head_html.label",
