[
  {
    "name": "theme_info",
    "theme_name": "products",
    "theme_label": "product hub",
    "theme_description": "B2B 企业 PIM 与产品数字资产枢纽。以「单品」为锚点，通过中心辐射结构聚合参数、物料、文档、知识库与客户案例；理性工业风格、Teal 主色，去电商化。",
    "theme_version": "1.0.0",
    "theme_syntax_version": "v2",
    "theme_scope": "cms",
    "theme_author": "Baklib",
    "theme_documentation_url": "https://help.baklib.cn/",
    "theme_support_url": "https://help.baklib.cn/",
    "theme_thumb_url": "images/theme/thumb.png",
    "theme_preview_images": [
      "images/theme/release-guide.png",
      "images/theme/index-card.png",
      "images/theme/page.png"
    ],
    "theme_languages": [
      { "name": "中文简体", "value": "zh-CN" },
      { "name": "中文繁體", "value": "zh-TW" },
      { "name": "한국어", "value": "ko" },
      { "name": "English", "value": "en" },
      { "name": "日本語", "value": "ja" }
    ],
    "recommendations": {
      "color_schemas": {
        "industrial_teal": {
          "name": "工业 Teal",
          "colors": {
            "--theme-color-primary": "#0d9488",
            "--theme-color-secondary": "#0f172a",
            "--theme-color-accent": "#64748b",
            "--theme-color-info": "#0284c7",
            "--theme-color-success": "#16a34a",
            "--theme-color-warning": "#d97706"
          }
        },
        "graphite": {
          "name": "石墨灰",
          "colors": {
            "--theme-color-primary": "#1e293b",
            "--theme-color-secondary": "#0d9488",
            "--theme-color-accent": "#94a3b8",
            "--theme-color-info": "#0ea5e9",
            "--theme-color-success": "#22c55e",
            "--theme-color-warning": "#f59e0b"
          }
        },
        "deep_ocean": {
          "name": "深海蓝",
          "colors": {
            "--theme-color-primary": "#0369a1",
            "--theme-color-secondary": "#0f172a",
            "--theme-color-accent": "#64748b",
            "--theme-color-info": "#06b6d4",
            "--theme-color-success": "#16a34a",
            "--theme-color-warning": "#ea580c"
          }
        }
      }
    }
  },
  {
    "name": "t:schema.generic.name",
    "settings": [
      {
        "id": "slogan",
        "type": "text",
        "label": "t:schema.generic.settings.slogan.label",
        "default": "t:schema.generic.settings.slogan.default"
      },
      {
        "id": "company_name",
        "label": "t:schema.generic.settings.company_name.label",
        "type": "text",
        "default": "t:schema.generic.settings.company_name.default",
        "info": "t:schema.generic.settings.company_name.info"
      },
      {
        "id": "copyright_info",
        "type": "text",
        "label": "t:schema.generic.settings.copyright_info.label",
        "placeholder": "t:schema.generic.settings.copyright_info.placeholder"
      },
      {
        "id": "sort_rule",
        "type": "select",
        "label": "t:schema.generic.settings.sort_rule.label",
        "choices": [
          {"label": "t:schema.generic.settings.sort_rule.options.created_at_desc", "value": "-created_at"},
          {"label": "t:schema.generic.settings.sort_rule.options.created_at_asc", "value": "created_at"},
          {"label": "t:schema.generic.settings.sort_rule.options.edited_at_desc", "value": "-edited_at"},
          {"label": "t:schema.generic.settings.sort_rule.options.edited_at_asc", "value": "edited_at"},
          {"label": "t:schema.generic.settings.sort_rule.options.visit_count_desc", "value": "-visit_count"},
          {"label": "t:schema.generic.settings.sort_rule.options.visit_count_asc", "value": "visit_count"},
          {"label": "t:schema.generic.settings.sort_rule.options.manual", "value": ""}
        ],
        "default": "-created_at"
      },
      {
        "id": "is_allow_feedback",
        "type": "checkbox",
        "label": "t:schema.generic.settings.is_allow_feedback.label",
        "default": true
      },
      {
        "id": "is_show_visit_count",
        "type": "checkbox",
        "label": "t:schema.generic.settings.is_show_visit_count.label",
        "default": false
      },
      {
        "id": "is_allow_header",
        "type": "checkbox",
        "label": "t:schema.generic.settings.is_allow_header.label",
        "default": true
      },
      {
        "id": "is_allow_footer",
        "type": "checkbox",
        "label": "t:schema.generic.settings.is_allow_footer.label",
        "default": true
      }
    ]
  },
