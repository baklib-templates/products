<!DOCTYPE html>
<html class="scroll-smooth products-theme font-sans text-base-content antialiased hub-selection" lang="{{ site.language }}">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="author" content="Baklib">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% meta_tags %}
    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {% assign _theme_build = site.updated_at | default: site.published_at | default: 'now' %}
    {{ 'javascripts/application.js' | asset_url | append: '?v=' | append: (_theme_build | date: '%s') | script_tag: defer: true, data-turbo-track: 'reload' }}
    {% if false %} {{ 'javascripts/cdn.tailwindcss.js' | asset_url | script_tag: data-turbo-track: 'reload' }} {% endif %}
    <style > :root
      {
        --color-base-100: hsl(var(--theme-color-base-100));
        --color-base-200: hsl(var(--theme-color-base-200));
        --color-base-300: hsl(var(--theme-color-base-300));
        --color-base-content: hsl(var(--theme-color-base-content));
        --color-primary: hsl(var(--theme-color-primary));
        --color-secondary: hsl(var(--theme-color-secondary));
        --color-accent: hsl(var(--theme-color-accent));
        --color-neutral: hsl(var(--theme-color-neutral));
        --color-info: hsl(var(--theme-color-info));
        --color-success: hsl(var(--theme-color-success));
        --color-warning: hsl(var(--theme-color-warning));
        --color-error: hsl(var(--theme-color-error));

        --max-content-width: {{ site.settings.screen_width.value | presence | default: '1200px' }};
        --left-sidebar-width: {{ site.settings.left_sidebar_width.value | presence | default: '240px' }};
        --right-sidebar-width: {{ site.settings.right_sidebar_width.value | presence | default: '240px' }};
        --header-height: {{ site.settings.header_height.value | presence | default: '68px' }};
      }

      :root:has(input.theme-controller[value=dark]:checked),
      [data-theme="dark"] {
        --color-base-100: hsl(var(--theme-color-base-100-dark));
        --color-base-200: hsl(var(--theme-color-base-200-dark));
        --color-base-300: hsl(var(--theme-color-base-300-dark));
        --color-base-content: hsl(var(--theme-color-base-content-dark));
        --color-primary: hsl(var(--theme-color-primary-dark));
        --color-secondary: hsl(var(--theme-color-secondary-dark));
        --color-accent: hsl(var(--theme-color-accent-dark));
        --color-neutral: hsl(var(--theme-color-neutral-dark));
        --color-info: hsl(var(--theme-color-info-dark));
        --color-success: hsl(var(--theme-color-success-dark));
        --color-warning: hsl(var(--theme-color-warning-dark));
        --color-error: hsl(var(--theme-color-error-dark));
      }
    </style>
    <style id="product-hub-a11y-fallbacks">
      
      @media (prefers-reduced-transparency: reduce) {
        .product-hub-glass,
        .product-hub-glass-fab,
        .product-hub-glass-strip {
          -webkit-backdrop-filter: none !important;
          backdrop-filter: none !important;
          background-color: Canvas !important;
          box-shadow: none !important;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .product-hub-glass-fab,
        .hub-liquid-card-interactive,
        .hub-pill-primary,
        .hub-pill-primary-sm,
        .hub-pill-secondary {
          transition: none !important;
        }
        .product-hub-glass-fab:hover {
          transform: none !important;
        }
      }
    </style>
    {{ site.settings.head_html }}

    {% weixin_share_tag app_id: site.settings.weixin_app_id, app_secret: site.settings.weixin_app_secret, debug: site.settings.weixin_debug, enabled: site.settings.weixin_enabled %}
  </head>
  <body id="js--body" class="relative flex min-h-screen flex-col font-sans text-base-content antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div class="absolute -left-[10%] -top-[10%] h-[50%] w-[50%] rounded-full bg-primary/20 blur-[120px]"></div>
      <div class="absolute -right-[10%] top-[20%] h-[60%] w-[60%] rounded-full bg-info/20 blur-[140px]"></div>
      <div class="absolute bottom-[-10%] left-[10%] h-[50%] w-[50%] rounded-full bg-info/15 blur-[120px]"></div>
      <div class="absolute inset-0 bg-base-200/40"></div>
    </div>

    <div class="flex-0">
      {% if site.settings.is_allow_header %}
        {% render 'header' %}
      {% endif %}
    </div>

    <main class="relative flex min-h-0 flex-1 flex-col bg-transparent">
      {{ content_for_layout }}
    </main>

    <div class="flex-0">
      {% if site.settings.is_allow_footer %}
        {% render 'footer' %}
      {% endif %}
    </div>
  </body>
</html>
