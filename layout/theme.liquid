<!DOCTYPE html>
<html class="scroll-smooth products-theme font-sans text-base-content antialiased hub-selection" lang="{{ site.language }}">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="author" content="Baklib">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% meta_tags %}

    {%- comment -%}
      Runtime color injection MUST be rendered BEFORE application.css so the
      daisyUI (themes: false) `--color-*` variables exist on first paint and
      avoid an unstyled / default-color flash. Static tokens and color scales
      live in src/stylesheets/application.css.
    {%- endcomment -%}
    {% render 'theme_runtime_colors' %}

    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {% assign _theme_build = site.updated_at | default: site.published_at | default: 'now' %}
    {{ 'javascripts/application.js' | asset_url | append: '?v=' | append: (_theme_build | date: '%s') | script_tag: defer: true, data-turbo-track: 'reload' }}
    {% if false %} {{ 'javascripts/cdn.tailwindcss.js' | asset_url | script_tag: data-turbo-track: 'reload' }} {% endif %}
    <style id="product-hub-a11y-fallbacks">
      @media (prefers-reduced-transparency: reduce) {
        .product-hub-glass,
        .product-hub-glass-fab {
          -webkit-backdrop-filter: none !important;
          backdrop-filter: none !important;
          background-color: var(--color-base-100) !important;
          box-shadow: none !important;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .product-hub-glass-fab {
          transition: none !important;
        }
        .product-hub-glass-fab:hover {
          transform: none !important;
        }
      }
    </style>
    {{ site.settings.head_html }}

    {% weixin_share_tag app_id: site.settings.weixin_app_id, app_secret: site.settings.weixin_app_secret, debug: site.settings.weixin_debug, enabled: site.settings.weixin_enabled %}
  </head>
  <body id="js--body" class="relative flex min-h-screen flex-col font-sans text-base-content antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div class="absolute -left-[10%] -top-[10%] h-[50%] w-[50%] rounded-full bg-primary/20 blur-[120px]"></div>
      <div class="absolute -right-[10%] top-[20%] h-[60%] w-[60%] rounded-full bg-info/20 blur-[140px]"></div>
      <div class="absolute bottom-[-10%] left-[10%] h-[50%] w-[50%] rounded-full bg-info/15 blur-[120px]"></div>
      <div class="absolute inset-0 bg-base-200/40"></div>
    </div>

    <div class="flex-0">
      {% if site.settings.is_allow_header %}
        {% render 'header' %}
      {% endif %}
    </div>

    <main class="relative flex min-h-0 flex-1 flex-col bg-transparent">
      {{ content_for_layout }}
    </main>

    <div class="flex-0">
      {% if site.settings.is_allow_footer %}
        {% render 'footer' %}
      {% endif %}
    </div>
  </body>
</html>
