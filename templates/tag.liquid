<div class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
  <header class="mb-6 border-b border-base-300 pb-6">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'tag.eyebrow' | t }}</p>
    <h1 class="mt-2 inline-flex items-center gap-3 text-2xl font-bold tracking-tight text-base-content sm:text-3xl">
      <span class="inline-block h-3 w-3 rounded-full" style="background-color: {{ tag.color }};"></span>
      #{{ tag.name }}
    </h1>
  </header>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_260px]">
    <section>
      <ul class="space-y-3">
        {% paginate_tag tag.pages, as: 'pages' %}
          {% for page in pages %}
            {% render 'card', page: page %}
          {% else %}
            {% render '@shared/empty', message: 'generic.empty' | t %}
          {% endfor %}
          <div class="mt-6">
            {% render '@shared/paginate' %}
          </div>
        {% endpaginate_tag %}
      </ul>
    </section>
    <aside class="lg:sticky lg:top-24 lg:self-start">
      {% render 'sidebar' %}
    </aside>
  </div>
</div>
