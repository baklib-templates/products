{%- comment -%}
  Product catalog overview (dictionary home): hero + taxonomy facets +
  product channel entries + featured product grid.
{%- endcomment -%}
{% assign channels = page.children_in_list %}
{% assign channels_count = channels | size %}
{% assign first_channel = channels | first %}
{% assign browse_path = first_channel.path | default: site.index_path | default: '/' %}
{% assign featured = page.pages_in_list | where: 'template_name', 'page' | order_by: '-edited_at' | limit: 8 %}
{% assign featured_count = featured | size %}

{% assign series_terms = site.settings.series | newline_to_br | split: '<br />' %}
{% assign industries_terms = site.settings.industries | newline_to_br | split: '<br />' %}
{% assign scenarios_terms = site.settings.scenarios | newline_to_br | split: '<br />' %}
{% assign quote_url = site.settings.cta_quote_url | default: '/s/quote' %}
{% assign quote_label = site.settings.cta_quote_label | default: 'hub.cta.quote' | t %}

<div class="mx-auto w-full max-w-7xl px-6 pb-16 pt-10">
  {%- comment -%} Hero {%- endcomment -%}
  <section class="mb-14">
    <h1 class="font-display text-4xl font-bold leading-none tracking-tight text-base-content md:text-5xl">{{ page.link_text }}</h1>
    {% if page.settings.description != blank %}
      <div class="ProseMirror2 prose2 mt-5 max-w-full text-lg text-base-content/70">{{ page.settings.description }}</div>
    {% else %}
      <p class="mt-5 max-w-2xl text-lg text-base-content/70">{{ 'index.intro' | t }}</p>
    {% endif %}
    <div class="mt-7 flex flex-wrap gap-3">
      <a href="{{ browse_path }}" class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-content shadow-sm transition-colors hover:bg-primary/90 no-underline" data-turbo-frame="main-content-frame" data-turbo-action="advance">
        {% render 'icon', name: 'grid', class: 'w-4 h-4' %}{{ 'index.cta_browse' | t }}
      </a>
      <a href="{{ quote_url }}" class="inline-flex items-center gap-2 rounded-lg border border-base-300 bg-base-100 px-5 py-2.5 text-sm font-medium text-base-content transition-colors hover:border-primary/40 hover:bg-primary/5 no-underline" data-turbo-frame="main-content-frame" data-turbo-action="advance">
        {% render 'icon', name: 'message-square', class: 'w-4 h-4' %}{{ quote_label }}
      </a>
    </div>
  </section>

  {%- comment -%} Taxonomy facets {%- endcomment -%}
  <section class="mb-14">
    <h2 class="mb-6 font-display text-2xl font-semibold text-base-content">{{ 'index.browse_title' | t }}</h2>
    <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
      {% assign facet_groups = 'series,industries,scenarios' | split: ',' %}
      {% for fg in facet_groups %}
        {% case fg %}
          {% when 'series' %}{% assign terms = series_terms %}{% assign facet_icon = 'layers' %}{% assign facet_label = 'index.facet.series' | t %}
          {% when 'industries' %}{% assign terms = industries_terms %}{% assign facet_icon = 'factory' %}{% assign facet_label = 'index.facet.industries' | t %}
          {% when 'scenarios' %}{% assign terms = scenarios_terms %}{% assign facet_icon = 'target' %}{% assign facet_label = 'index.facet.scenarios' | t %}
        {% endcase %}
        <div class="rounded-2xl border border-base-300 bg-base-200 p-6">
          <h3 class="mb-4 inline-flex items-center gap-2 text-sm font-semibold text-base-content">
            <span class="text-primary">{% render 'icon', name: facet_icon, class: 'w-5 h-5' %}</span>{{ facet_label }}
          </h3>
          <div class="flex flex-wrap gap-2">
            {% for term in terms %}
              {% assign term = term | strip %}
              {% if term != blank %}
                <a href="{{ site.search_path }}?q={{ term | url_encode }}" class="inline-flex items-center rounded-lg bg-base-300 px-2.5 py-1 text-xs text-base-content/80 transition-colors hover:bg-primary/10 hover:text-primary no-underline" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ term }}</a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </section>

  {%- comment -%} Product channels {%- endcomment -%}
  <section class="mb-14">
    <div class="mb-6 flex items-baseline justify-between">
      <h2 class="font-display text-2xl font-semibold text-base-content">{{ 'index.channels_title' | t }}</h2>
    </div>
    {% if channels_count == 0 %}
      {% render '@shared/empty', message: 'index.empty_channels' | t %}
    {% else %}
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {% for channel in channels %}
          {% assign ch_count = channel.pages_in_list | where: 'template_name', 'page' | size %}
          <a href="{{ channel.path }}" class="group flex flex-col rounded-2xl border border-base-300 bg-base-200 p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md no-underline" data-turbo-frame="main-content-frame" data-turbo-action="advance">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-primary/10 text-primary">{% render 'icon', name: 'boxes', class: 'w-5 h-5' %}</div>
            <h3 class="font-display text-lg font-semibold text-base-content transition-colors group-hover:text-primary">{{ channel.link_text }}</h3>
            {% if channel.settings.description != blank %}
              <p class="mt-2 line-clamp-2 text-sm text-base-content/70">{{ channel.settings.description | strip_html | strip }}</p>
            {% endif %}
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-primary">
              {{ ch_count }} {{ 'channels.products.count' | t }}{% render 'icon', name: 'arrow-right', class: 'w-4 h-4' %}
            </span>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </section>

  {%- comment -%} Featured products {%- endcomment -%}
  {% if featured_count > 0 %}
    <section>
      <div class="mb-6 flex items-baseline justify-between">
        <h2 class="font-display text-2xl font-semibold text-base-content">{{ 'index.featured_products' | t }}</h2>
        <a href="{{ browse_path }}" class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'index.view_all' | t }}{% render 'icon', name: 'arrow-right', class: 'w-4 h-4' %}</a>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {% for product in featured %}
          {% render 'product_card', page: product %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
</div>

{% schema %}
  {
    "name": "t:schema.templates.index.name",
    "description": "t:schema.templates.index.description",
    "thumb_url": "images/theme/${lang}/index.png",
    "preview_image_urls": [
      "images/theme/${lang}/index.png"
    ],
    "sub_page_templates": ["channel"],
    "settings": [
      {
        "id": "description",
        "type": "richtext",
        "label": "t:schema.templates.index.settings.description.label",
        "info": "t:schema.templates.index.settings.description.info"
      }
    ]
  }
{% endschema %}
