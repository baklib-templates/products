{%- comment -%}
  全局资料库（products-demo Resource Center）：左侧 Filters，右侧玻璃卡片列表。
{%- endcomment -%}
{% assign sort_rule = site.settings.sort_rule.value | default: site.settings.sort_rule | default: '-edited_at' %}
{% assign downloads = page.pages_in_list | order_by: sort_rule %}
{% assign downloads_count = downloads | size %}
{% capture _title %}{{ page.link_text }}{% endcapture %}
{% set_meta_title _title | strip %}

<div class="mx-auto w-full max-w-[1280px] px-6 pb-16 pt-8" x-data="{ q: '', type: 'all' }">
  {% render '@shared/breadcrumb', breadcrumb: page.breadcrumb %}

  <h1 class="mb-12 font-display text-5xl font-bold tracking-tight text-base-content">{{ page.link_text }}</h1>

  <div class="flex flex-col gap-8 lg:flex-row lg:gap-16">
    <aside class="w-full shrink-0 space-y-8 lg:sticky lg:top-32 lg:w-[240px]">
      <h2 class="mb-6 flex items-center gap-2 font-mono text-[12px] font-medium uppercase text-base-content/50">
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
        {{ 'channels.downloads.filters' | t }}
      </h2>
      <div>
        <h3 class="mb-4 text-[14px] font-semibold text-base-content">{{ 'channels.downloads.filter_format' | t }}</h3>
        <div class="mb-8 space-y-3">
          {% for label in 'PDF Document,ZIP Archive,CAD Model' | split: ',' %}
            <label class="group flex cursor-pointer items-center gap-3">
              <div class="flex h-4 w-4 items-center justify-center rounded border border-base-300 bg-base-200 transition-colors group-hover:border-base-content"></div>
              <span class="text-[14px] text-base-content/70 transition-colors group-hover:text-base-content">{{ label }}</span>
            </label>
          {% endfor %}
        </div>
        <h3 class="mb-4 text-[14px] font-semibold text-base-content">{{ 'channels.downloads.filter_category' | t }}</h3>
        <div class="space-y-3">
          {% for label in 'Cobots,AMR/AGV,Vision Systems' | split: ',' %}
            <label class="group flex cursor-pointer items-center gap-3">
              <div class="flex h-4 w-4 items-center justify-center rounded border border-base-300 bg-base-200 transition-colors group-hover:border-base-content"></div>
              <span class="text-[14px] text-base-content/70 transition-colors group-hover:text-base-content">{{ label }}</span>
            </label>
          {% endfor %}
        </div>
      </div>
    </aside>

    <div class="min-w-0 flex-1 space-y-4">
      {% assign intro = page.settings.intro | strip %}
      {% if intro != blank %}
        <p class="mb-6 max-w-3xl text-sm leading-relaxed text-base-content/70 sm:text-base">{{ intro }}</p>
      {% endif %}

      <div class="relative mb-6 w-full md:w-80">
        <svg class="pointer-events-none absolute left-5 top-1/2 h-4 w-4 -translate-y-1/2 text-base-content/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" x-model.debounce.150ms="q" placeholder="{{ 'channels.downloads.search_placeholder' | t }}" class="hub-search-input" />
      </div>

      {% if downloads_count == 0 %}
        {% render '@shared/empty', message: 'channels.downloads.empty' | t %}
      {% else %}
        {% for d in downloads %}
          {% assign file_url = d.settings.file_url | strip %}
          {% assign file_type = d.settings.file_type | strip | downcase %}
          {% if file_type == blank and file_url != blank %}
            {% assign _ext_parts = file_url | split: '.' %}
            {% assign file_type = _ext_parts.last | downcase | split: '?' | first %}
          {% endif %}
          {% assign file_size = d.settings.file_size | strip %}
          {% assign related_model = d.settings.product_model | default: d.settings.related_models | strip %}
          {% assign keywords = d.link_text | append: ' ' | append: related_model | append: ' ' | append: file_type | downcase %}
          <div
            data-download-row
            x-show="q === '' || '{{ keywords | escape_once }}'.indexOf(q.toLowerCase()) >= 0"
            class="hub-liquid-card flex cursor-pointer items-center gap-6 p-6 transition-all hover:-translate-y-0.5 hover:bg-base-200"
          >
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-base-200 bg-base-100 text-primary shadow-sm">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div class="min-w-0 flex-1">
              <a href="{{ d.path }}" class="mb-1 block text-[16px] font-medium text-base-content hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ d.link_text }}</a>
              <div class="flex flex-wrap gap-4 font-mono text-[13px] text-base-content/60">
                {% if related_model != blank %}<span class="text-accent">{{ related_model }}</span>{% endif %}
                {% if file_type != blank %}<span>{{ file_type | upcase }}</span>{% endif %}
                {% if file_size != blank %}<span>{{ file_size }}</span>{% endif %}
              </div>
            </div>
            {% if file_url != blank %}
              <a href="{{ file_url }}" target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-base-content text-base-content transition-colors hover:bg-neutral hover:text-neutral-content" aria-label="{{ 'channels.downloads.download' | t }}">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              </a>
            {% else %}
              <a href="{{ d.path }}" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-base-content text-base-content transition-colors hover:bg-neutral hover:text-neutral-content" data-turbo-frame="main-content-frame" data-turbo-action="advance" aria-label="{{ 'channels.downloads.view_detail' | t }}">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.channel_downloads.name",
    "description": "t:schema.templates.channel_downloads.description",
    "thumb_url": "images/theme/index-list.png",
    "sub_page_templates": ["page"],
    "settings": [
      {
        "id": "intro",
        "type": "textarea",
        "label": "t:schema.templates.channel.settings.intro.label",
        "info": "t:schema.templates.channel.settings.intro.info"
      }
    ]
  }
{% endschema %}
