{%- comment -%}
  Page 兜底模板：未选具体样式时按通用详情渲染。
  推荐为单品 / 案例 / 文档分别指定 page.product / page.case / page.doc 样式。
{%- endcomment -%}
{% capture _title %}{{ page.link_text }}{% endcapture %}
{% set_meta_title _title | strip %}
{% if page.settings.tagline != blank %}
  {% set_meta_description page.settings.tagline %}
{% endif %}

<article class="mx-auto w-full max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
  {% render '@shared/breadcrumb', breadcrumb: page.breadcrumb %}

  <header class="mt-4 border-b border-base-300 pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-base-content sm:text-4xl">{{ page.link_text }}</h1>
    {% if page.settings.tagline != blank %}
      <p class="mt-2 max-w-3xl text-base text-base-content/70">{{ page.settings.tagline }}</p>
    {% endif %}
    <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-base-content/60">
      <span>{{ page.published_at | date: '%Y-%m-%d' }}</span>
      {% if site.settings.is_show_visit_count %}
        <span>{{ 'templates.page.visit_count' | t }}: {{ page.visits_count }}</span>
      {% endif %}
      {% for tag in page.tags %}
        {% render 'tag', tag: tag %}
      {% endfor %}
    </div>
  </header>

  <div id="page-content" class="prose prose mt-8 max-w-none">
    {{ page.settings.body }}
  </div>

  {% if site.settings.is_allow_feedback %}
    <div class="mt-10 border-t border-base-300 pt-8">
      {% render 'feedback_button', page: page %}
    </div>
  {% endif %}
</article>

{% schema %}
  {
    "name": "t:schema.templates.page.name",
    "description": "t:schema.templates.page.description",
    "thumb_url": "images/theme/page.png",
    "sub_page_templates": ["page"],
    "settings": [
      {
        "id": "tagline",
        "type": "text",
        "label": "t:schema.templates.page.settings.tagline.label"
      },
      {
        "id": "body",
        "type": "richtext",
        "to_markdown": true,
        "label": "t:schema.templates.page.settings.body.label"
      },
      {
        "id": "product_model",
        "type": "text",
        "label": "t:schema.templates.page.settings.product_model.label",
        "info": "t:schema.templates.page.settings.product_model.info"
      },
      {
        "id": "related_models",
        "type": "textarea",
        "label": "t:schema.templates.page.settings.related_models.label",
        "info": "t:schema.templates.page.settings.related_models.info",
        "rows": 3
      },
      {
        "id": "file_url",
        "type": "text",
        "label": "t:schema.templates.page.settings.file_url.label",
        "info": "t:schema.templates.page.settings.file_url.info"
      },
      {
        "id": "file_type",
        "type": "text",
        "label": "t:schema.templates.page.settings.file_type.label"
      },
      {
        "id": "file_size",
        "type": "text",
        "label": "t:schema.templates.page.settings.file_size.label"
      }
    ]
  }
{% endschema %}
