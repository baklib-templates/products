{%- comment -%}
  案例详情页：商业叙事版式。
  page.settings：
    - client_name 客户名
    - client_logo_url 客户 logo
    - industry 行业
    - headline_metric 显著成效（如「上线后处理效率提升 38%」）
    - pain_point 痛点（textarea）
    - solution 解决方案（richtext）
    - outcomes 量化成果（每行一条，格式 `数值｜单位｜说明`）
    - body 主要正文（richtext）
    - related_models 关联型号（每行一个；与 page.product 跨栏目匹配）
{%- endcomment -%}
{% capture _title %}{{ page.link_text }}{% endcapture %}
{% set_meta_title _title | strip %}
{% if page.settings.pain_point != blank %}
  {% set_meta_description page.settings.pain_point %}
{% endif %}

{% assign cover = page.settings.cover_image_url | default: page.settings.hero_image_url | presence %}
{% assign client_logo = page.settings.client_logo_url | presence %}

<article class="bg-base-200">
  <div class="mx-auto w-full max-w-6xl px-4 pb-4 pt-6 sm:px-6 lg:px-8">
    {% render '@shared/breadcrumb', breadcrumb: page.breadcrumb %}
  </div>

  <header class="border-b border-base-300 bg-base-100">
    <div class="mx-auto grid w-full max-w-6xl gap-8 px-4 py-10 sm:px-6 md:grid-cols-[minmax(0,1fr)_360px] lg:px-8">
      <div>
        <div class="flex flex-wrap items-center gap-3 text-xs text-base-content/60">
          {% if page.settings.industry != blank %}
            <span class="rounded bg-base-200 px-2 py-0.5 text-[11px] font-medium text-base-content/70">{{ page.settings.industry }}</span>
          {% endif %}
          <span class="font-mono">{{ page.published_at | date: '%Y-%m-%d' }}</span>
        </div>
        <h1 class="mt-3 text-3xl font-bold tracking-tight text-base-content sm:text-4xl">{{ page.link_text }}</h1>
        {% if page.settings.tagline != blank %}
          <p class="mt-2 max-w-2xl text-base text-base-content/70">{{ page.settings.tagline }}</p>
        {% endif %}
        {% if client_logo or page.settings.client_name %}
          <div class="mt-6 flex items-center gap-4 border-t border-base-200 pt-5">
            {% if client_logo %}
              <img src="{{ client_logo }}" alt="" class="h-10 max-w-[140px] object-contain" loading="lazy" />
            {% endif %}
            <div class="text-sm">
              <p class="font-semibold text-base-content">{{ page.settings.client_name }}</p>
              {% if page.settings.client_caption != blank %}<p class="text-base-content/60">{{ page.settings.client_caption }}</p>{% endif %}
            </div>
          </div>
        {% endif %}
      </div>
      {% if cover %}
        <div class="overflow-hidden rounded-md ring-1 ring-base-300">
          <img src="{{ cover }}" alt="" class="h-full w-full object-cover" loading="lazy" />
        </div>
      {% endif %}
    </div>
  </header>

  <div class="mx-auto w-full max-w-6xl grid gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[minmax(0,1fr)_300px] lg:px-8">
    <div class="space-y-10">
      {% if page.settings.headline_metric != blank %}
        <section class="rounded-md border border-primary/30 bg-primary/5 p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">{{ 'page.case.headline_metric' | t }}</p>
          <p class="mt-2 text-xl font-semibold text-primary sm:text-2xl">{{ page.settings.headline_metric }}</p>
        </section>
      {% endif %}

      {% if page.settings.pain_point != blank %}
        <section>
          <h2 class="text-lg font-semibold text-base-content">{{ 'page.case.pain_point' | t }}</h2>
          <div class="mt-3 rounded-md border border-base-300 bg-base-100 p-5 text-sm leading-relaxed text-base-content/80">{{ page.settings.pain_point | newline_to_br }}</div>
        </section>
      {% endif %}

      {% if page.settings.solution != blank %}
        <section>
          <h2 class="text-lg font-semibold text-base-content">{{ 'page.case.solution' | t }}</h2>
          <div class="prose prose mt-3 max-w-none rounded-md border border-base-300 bg-base-100 p-6">{{ page.settings.solution }}</div>
        </section>
      {% endif %}

      {% assign outcomes_raw = page.settings.outcomes | strip %}
      {% if outcomes_raw != blank %}
        <section>
          <h2 class="text-lg font-semibold text-base-content">{{ 'page.case.outcomes' | t }}</h2>
          {% assign outcome_lines = outcomes_raw | newline_to_br | split: '<br />' %}
          <div class="mt-3 grid gap-4 sm:grid-cols-3">
            {% for line in outcome_lines %}
              {% assign line = line | strip %}
              {% if line != blank %}
                {% assign parts = line | split: '|' %}
                {% assign val = parts[0] | strip %}
                {% assign unit = parts[1] | strip %}
                {% assign label = parts[2] | strip %}
                <div class="rounded-md border border-base-300 bg-base-100 p-4 text-center">
                  <p class="text-2xl font-bold text-primary">{{ val }}<span class="ml-1 text-base font-medium text-base-content/60">{{ unit }}</span></p>
                  {% if label != blank %}<p class="mt-1 text-xs text-base-content/60">{{ label }}</p>{% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if page.settings.body != blank %}
        <section id="page-content" class="prose prose max-w-none rounded-md border border-base-300 bg-base-100 p-6 sm:p-8">
          {{ page.settings.body }}
        </section>
      {% endif %}
    </div>

    <aside class="space-y-4 lg:sticky lg:top-28 lg:self-start">
      <div class="rounded-md border border-base-300 bg-base-100 p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'page.case.about_client' | t }}</p>
        <dl class="mt-3 space-y-2 text-sm">
          {% if page.settings.client_name %}
            <div class="flex items-baseline justify-between gap-3"><dt class="text-base-content/60">{{ 'page.case.client_name' | t }}</dt><dd class="font-medium text-base-content">{{ page.settings.client_name }}</dd></div>
          {% endif %}
          {% if page.settings.industry %}
            <div class="flex items-baseline justify-between gap-3"><dt class="text-base-content/60">{{ 'page.case.industry' | t }}</dt><dd class="text-base-content">{{ page.settings.industry }}</dd></div>
          {% endif %}
          {% if page.settings.region %}
            <div class="flex items-baseline justify-between gap-3"><dt class="text-base-content/60">{{ 'page.case.region' | t }}</dt><dd class="text-base-content">{{ page.settings.region }}</dd></div>
          {% endif %}
          {% if page.settings.scale %}
            <div class="flex items-baseline justify-between gap-3"><dt class="text-base-content/60">{{ 'page.case.scale' | t }}</dt><dd class="text-base-content">{{ page.settings.scale }}</dd></div>
          {% endif %}
        </dl>
      </div>

      {% assign related = page.settings.related_models | strip %}
      {% if related != blank %}
        <div class="rounded-md border border-base-300 bg-base-100 p-5">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'page.case.related_products' | t }}</p>
          {% assign lines = related | newline_to_br | split: '<br />' %}
          {% assign products_root = site.settings.products_root_path | default: '/products' %}
          {% assign all_products = site.pages[products_root].pages_in_list %}
          <ul class="mt-3 space-y-2 text-sm">
            {% for m in lines %}
              {% assign m = m | strip %}
              {% if m != blank %}
                {% assign matched = nil %}
                {% for p in all_products %}
                  {% if matched == nil and p.settings.product_model == m %}
                    {% assign matched = p %}
                  {% endif %}
                {% endfor %}
                <li>
                  {% if matched %}
                    <a href="{{ matched.path }}" class="flex items-center justify-between rounded px-2 py-1 hover:bg-base-200 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">
                      <span class="line-clamp-1">{{ matched.link_text }}</span>
                      <span class="font-mono text-[11px] text-base-content/50">{{ m }}</span>
                    </a>
                  {% else %}
                    <span class="font-mono text-base-content/60">{{ m }}</span>
                  {% endif %}
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      <div class="rounded-md border border-base-300 bg-base-100 p-5">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'page.case.cta' | t }}</p>
        <p class="mt-2 text-sm text-base-content/70">{{ 'page.case.cta_desc' | t }}</p>
        <button type="button" class="btn btn-sm mt-3 w-full bg-primary text-primary-content shadow-sm hover:bg-primary/90" data-lead-trigger data-lead-intent="quote" data-lead-label="{{ site.settings.cta_quote_label | default: 'hub.cta.quote' | t | escape_once }} · {{ page.link_text | escape_once }}">
          {{ site.settings.cta_quote_label | default: 'hub.cta.quote' | t }}
        </button>
      </div>
    </aside>
  </div>
</article>

{% schema %}
  {
    "name": "t:schema.templates.page_case.name",
    "description": "t:schema.templates.page_case.description",
    "thumb_url": "images/theme/page.png",
    "sub_page_templates": ["page"],
    "settings": [
      {
        "id": "tagline",
        "type": "text",
        "label": "t:schema.templates.page_case.settings.tagline.label"
      },
      {
        "id": "client_name",
        "type": "text",
        "label": "t:schema.templates.page_case.settings.client_name.label"
      },
      {
        "id": "client_caption",
        "type": "text",
        "label": "t:schema.templates.page_case.settings.client_caption.label"
      },
      {
        "id": "client_logo_url",
        "type": "image_picker",
        "label": "t:schema.templates.page_case.settings.client_logo_url.label"
      },
      {
        "id": "cover_image_url",
        "type": "image_picker",
        "label": "t:schema.templates.page_case.settings.cover_image_url.label"
      },
      {
        "id": "industry",
        "type": "text",
        "label": "t:schema.templates.page_case.settings.industry.label"
      },
      {
        "id": "region",
        "type": "text",
        "label": "t:schema.templates.page_case.settings.region.label"
      },
      {
        "id": "scale",
        "type": "text",
        "label": "t:schema.templates.page_case.settings.scale.label"
      },
      {
        "id": "headline_metric",
        "type": "text",
        "label": "t:schema.templates.page_case.settings.headline_metric.label",
        "info": "t:schema.templates.page_case.settings.headline_metric.info"
      },
      {
        "id": "pain_point",
        "type": "textarea",
        "label": "t:schema.templates.page_case.settings.pain_point.label",
        "rows": 4
      },
      {
        "id": "solution",
        "type": "richtext",
        "label": "t:schema.templates.page_case.settings.solution.label"
      },
      {
        "id": "outcomes",
        "type": "textarea",
        "label": "t:schema.templates.page_case.settings.outcomes.label",
        "info": "t:schema.templates.page_case.settings.outcomes.info",
        "rows": 4
      },
      {
        "id": "body",
        "type": "richtext",
        "to_markdown": true,
        "label": "t:schema.templates.page_case.settings.body.label"
      },
      {
        "id": "related_models",
        "type": "textarea",
        "label": "t:schema.templates.page_case.settings.related_models.label",
        "rows": 3
      }
    ]
  }
{% endschema %}
