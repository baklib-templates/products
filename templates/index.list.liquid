{%- comment -%}
  首页变体：列表样式（适合知识中心型站点）。
  按子页列表分页展示，每行卡片格式。
{%- endcomment -%}
{% assign sort_rule = site.settings.sort_rule.value | default: site.settings.sort_rule | default: '-created_at' %}
{% assign pages = page.children_in_list | order_by: sort_rule %}

<div class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
  <header class="mb-6 border-b border-base-300 pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-base-content sm:text-4xl">{{ page.link_text }}</h1>
    {% if page.settings.description != blank %}
      <div class="prose prose mt-3 max-w-3xl">{{ page.settings.description }}</div>
    {% endif %}
  </header>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_260px]">
    <section>
      {% paginate_tag pages, per: 12 %}
        <div class="space-y-3">
          {% for page in pages %}
            {% render 'card', page: page %}
          {% else %}
            {% render '@shared/empty', message: 'generic.empty' | t %}
          {% endfor %}
        </div>
        <div class="mt-6">
          {% render '@shared/paginate' %}
        </div>
      {% endpaginate_tag %}
    </section>
    <aside class="lg:sticky lg:top-24 lg:self-start">
      {% render 'sidebar' %}
    </aside>
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.index_list.name",
    "description": "t:schema.templates.index_list.description",
    "thumb_url": "images/theme/index-list.png",
    "sub_page_templates": ["channel"]
  }
{% endschema %}
