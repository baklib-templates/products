{%- comment -%}
  全局案例库（products-demo Case Studies）：左侧 Filters + 搜索，右侧大卡片网格。
{%- endcomment -%}
{% assign sort_rule = site.settings.sort_rule.value | default: site.settings.sort_rule | default: '-created_at' %}
{% assign cases = page.pages_in_list | order_by: sort_rule %}
{% assign cases_count = cases | size %}
{% capture _title %}{{ page.link_text }}{% endcapture %}
{% set_meta_title _title | strip %}

<div class="mx-auto w-full max-w-[1280px] px-6 pb-16 pt-8" x-data="{ q: '' }">
  {% render '@shared/breadcrumb', breadcrumb: page.breadcrumb %}

  <h1 class="mb-12 font-display text-5xl font-bold tracking-tight text-base-content md:text-6xl">{{ page.link_text }}</h1>

  <div class="flex flex-col gap-8 lg:flex-row lg:gap-16">
    <aside class="w-full shrink-0 space-y-8 lg:sticky lg:top-32 lg:w-[240px]">
      <h2 class="mb-6 flex items-center gap-2 font-mono text-[12px] font-medium uppercase text-base-content/50">
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
        {{ 'channels.cases.filters' | t }}
      </h2>
      <div>
        <h3 class="mb-4 text-[14px] font-semibold text-base-content">{{ 'channels.cases.filter_industry' | t }}</h3>
        <div class="mb-8 space-y-3">
          {% for f in 'Semiconductor,Automotive,Consumer Electronics,Logistics,Packaging' | split: ',' %}
            <label class="group flex cursor-pointer items-center gap-3">
              <div class="flex h-4 w-4 items-center justify-center rounded border border-base-300 bg-base-200 transition-colors group-hover:border-base-content"></div>
              <span class="text-[14px] text-base-content/70 transition-colors group-hover:text-base-content">{{ f }}</span>
            </label>
          {% endfor %}
        </div>
        <h3 class="mb-4 text-[14px] font-semibold text-base-content">{{ 'channels.cases.filter_application' | t }}</h3>
        <div class="space-y-3">
          {% for f in 'Material Handling,Assembly,Inspection,Dispensing' | split: ',' %}
            <label class="group flex cursor-pointer items-center gap-3">
              <div class="flex h-4 w-4 items-center justify-center rounded border border-base-300 bg-base-200 transition-colors group-hover:border-base-content"></div>
              <span class="text-[14px] text-base-content/70 transition-colors group-hover:text-base-content">{{ f }}</span>
            </label>
          {% endfor %}
        </div>
      </div>
    </aside>

    <div class="min-w-0 flex-1">
      {% assign intro = page.settings.intro | strip %}
      {% if intro != blank %}
        <p class="mb-8 max-w-3xl text-sm leading-relaxed text-base-content/70 sm:text-base">{{ intro }}</p>
      {% endif %}

      <div class="relative mb-10 w-full md:w-80">
        <svg class="pointer-events-none absolute left-5 top-1/2 h-4 w-4 -translate-y-1/2 text-base-content/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" x-model.debounce.150ms="q" placeholder="{{ 'channels.cases.search_placeholder' | t }}" class="hub-search-input" />
      </div>

      {% if cases_count == 0 %}
        {% render '@shared/empty', message: 'channels.cases.empty' | t %}
      {% else %}
        {% paginate_tag cases, per: 24 %}
          <div class="grid grid-cols-1 gap-8 xl:grid-cols-2">
            {% for c in cases %}
              {% assign cover = c.settings.cover_image_url | default: c.settings.hero_image_url | default: c.settings.thumb_image_url | presence %}
              {% assign client_logo = c.settings.client_logo_url | presence %}
              {% assign pain = c.settings.pain_point | strip | default: c.settings.tagline | strip %}
              {% assign industry = c.settings.industry | strip %}
              {% assign client_name = c.settings.client_name | default: c.link_text | strip %}
              {% assign kw = c.link_text | append: ' ' | append: industry | append: ' ' | append: pain | downcase %}
              <article
                x-show="q === '' || '{{ kw | escape_once }}'.indexOf(q.toLowerCase()) >= 0"
                class="group hub-liquid-card-interactive flex cursor-pointer flex-col overflow-hidden"
              >
                <a href="{{ c.path }}" class="relative flex h-[240px] items-center justify-center overflow-hidden bg-base-200" data-turbo-frame="main-content-frame" data-turbo-action="advance">
                  {% if cover %}
                    <img src="{{ cover }}" alt="" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
                  {% else %}
                    <svg class="h-16 w-16 text-primary-content mix-blend-overlay" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  {% endif %}
                  <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
                </a>
                <div class="flex flex-1 flex-col border-t border-base-200 bg-base-100 p-8">
                  <div class="mb-6 inline-flex items-center gap-2 self-start rounded-full border border-base-300 bg-base-200 px-3 py-1.5 font-mono text-[12px] font-semibold text-base-content shadow-sm">
                    {% if client_logo %}
                      <img src="{{ client_logo }}" alt="" class="h-5 max-w-[72px] object-contain" loading="lazy" />
                    {% endif %}
                    {% if industry != blank %}
                      <span>{{ industry }}</span>
                    {% else %}
                      <span>{{ client_name }}</span>
                    {% endif %}
                  </div>
                  <h3 class="font-display mb-6 flex-1 text-2xl font-bold leading-snug text-base-content">
                    <a href="{{ c.path }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ c.link_text }}</a>
                  </h3>
                  {% if pain != blank %}
                    <p class="mb-4 line-clamp-2 text-sm text-base-content/70">{{ pain | strip_html | truncate: 160 }}</p>
                  {% endif %}
                  <div class="flex items-center justify-between border-t border-base-200 pt-4 text-[15px] font-medium text-primary group/link">
                    {{ 'channels.cases.read_full' | t }}
                    <svg class="h-5 w-5 transition-transform group-hover/link:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
          <div class="mt-8">
            {% render '@shared/paginate' %}
          </div>
        {% endpaginate_tag %}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.channel_cases.name",
    "description": "t:schema.templates.channel_cases.description",
    "thumb_url": "images/theme/index-card.png",
    "sub_page_templates": ["page.case"],
    "settings": [
      {
        "id": "intro",
        "type": "textarea",
        "label": "t:schema.templates.channel.settings.intro.label",
        "info": "t:schema.templates.channel.settings.intro.info"
      }
    ]
  }
{% endschema %}
