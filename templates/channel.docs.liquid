{%- comment -%}
  全局支持库：左侧目录树 + 右侧概览。子页通过 page.doc.liquid 渲染（Turbo frame 主内容切换）。
{%- endcomment -%}
{% assign sort_rule = site.settings.sort_rule.value | default: site.settings.sort_rule | default: '-created_at' %}
{% capture _title %}{{ page.link_text }}{% endcapture %}
{% set_meta_title _title | strip %}

<div class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  {% render '@shared/breadcrumb', breadcrumb: page.breadcrumb %}

  <header class="mt-4 flex flex-col gap-2 border-b border-base-300 pb-6">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">{{ 'channels.docs.eyebrow' | t }}</p>
    <h1 class="text-3xl font-bold tracking-tight text-base-content sm:text-4xl">{{ page.link_text }}</h1>
    {% assign intro = page.settings.intro | strip %}
    {% if intro != blank %}
      <p class="max-w-3xl text-sm leading-relaxed text-base-content/70 sm:text-base">{{ intro }}</p>
    {% endif %}
  </header>

  <div class="mt-8 grid gap-6 lg:grid-cols-[280px_minmax(0,1fr)]">
    <aside class="lg:sticky lg:top-24 lg:self-start">
      <div class="rounded-md border border-base-300 bg-base-100 p-2">
        <p class="px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'channels.docs.toc' | t }}</p>
        {% assign tree = page | nav_tree: 3 %}
        {% assign tree_count = tree | size %}
        {% if tree_count > 0 %}
          {% render 'nav_tree', nav_tree: tree, current_path: page.path %}
        {% else %}
          <p class="px-3 py-4 text-sm text-base-content/60">{{ 'generic.empty' | t }}</p>
        {% endif %}
      </div>
    </aside>

    <section>
      {% assign recent = page.pages_in_list | order_by: sort_rule | limit: 24 %}
      {% assign recent_count = recent | size %}
      <div class="rounded-md border border-base-300 bg-base-100 p-6 sm:p-8">
        <h2 class="text-lg font-semibold text-base-content">{{ 'channels.docs.recent' | t }}</h2>
        {% if recent_count == 0 %}
          <p class="mt-4 text-sm text-base-content/60">{{ 'generic.empty' | t }}</p>
        {% else %}
          <ul class="mt-4 divide-y divide-base-200">
            {% for d in recent %}
              <li class="flex flex-col gap-1 py-3 sm:flex-row sm:items-baseline sm:justify-between">
                <a href="{{ d.path }}" class="text-sm font-medium text-base-content hover:text-primary hover:underline" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ d.link_text }}</a>
                <span class="font-mono text-[11px] text-base-content/50">{{ d.edited_at | default: d.published_at | date: '%Y-%m-%d' }}</span>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </section>
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.channel_docs.name",
    "description": "t:schema.templates.channel_docs.description",
    "thumb_url": "images/theme/index-list.png",
    "sub_page_templates": ["page.doc"],
    "settings": [
      {
        "id": "intro",
        "type": "textarea",
        "label": "t:schema.templates.channel.settings.intro.label",
        "info": "t:schema.templates.channel.settings.intro.info"
      }
    ]
  }
{% endschema %}
