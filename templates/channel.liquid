{%- comment -%}
  Channel 兜底模板：未选择具体样式时按通用列表渲染。
  推荐为不同业务频道选择 channel.products / channel.cases / channel.docs / channel.downloads / channel.faqs 样式。
{%- endcomment -%}
{% capture _title %}{{ page.link_text }}{% endcapture %}
{% set_meta_title _title | strip %}

<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
  {% render '@shared/breadcrumb', breadcrumb: page.breadcrumb %}

  <header class="mt-4">
    <h1 class="text-2xl font-bold tracking-tight text-base-content sm:text-3xl">{{ page.link_text }}</h1>
    {% assign intro = page.settings.intro | strip %}
    {% if intro != blank %}
      <p class="mt-2 max-w-3xl text-sm leading-relaxed text-base-content/70">{{ intro }}</p>
    {% endif %}
  </header>

  <div class="mt-8 grid gap-6 lg:grid-cols-[260px_minmax(0,1fr)]">
    <aside class="lg:sticky lg:top-24">
      {% render 'sidebar' %}
    </aside>
    <section>
      {% assign items = page.children_in_list %}
      {% assign items_count = items | size %}
      {% if items_count == 0 %}
        {% render '@shared/empty', message: 'generic.empty' | t %}
      {% else %}
        <ul class="divide-y divide-base-300 rounded-md border border-base-300 bg-base-100">
          {% paginate_tag items, per: 20 %}
            {% for page in items %}
              <li class="px-4 sm:px-5">{% render 'list', page: page %}</li>
            {% endfor %}
            <li class="px-4 py-4 sm:px-5">{% render '@shared/paginate' %}</li>
          {% endpaginate_tag %}
        </ul>
      {% endif %}
    </section>
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.channel.name",
    "description": "t:schema.templates.channel.description",
    "thumb_url": "images/theme/index-list.png",
    "sub_page_templates": ["page","channel"],
    "settings": [
      {
        "id": "intro",
        "type": "textarea",
        "label": "t:schema.templates.channel.settings.intro.label",
        "info": "t:schema.templates.channel.settings.intro.info"
      }
    ]
  }
{% endschema %}
