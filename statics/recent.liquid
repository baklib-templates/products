{%- comment -%}
  最近更新静态页：列出最近编辑/发布的页面，便于运营了解动态。
{%- endcomment -%}
{% layout 'theme' %}
{% capture _title %}{{ 'generic.recent_updates' | t }}{% endcapture %}
{% set_meta_title _title | strip %}
{% assign pages = site.pages_in_list | order_by: '-edited_at' | limit: 20 %}

<div class="mx-auto w-full max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
  <header class="mb-6 border-b border-base-300 pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-base-content sm:text-4xl">{{ 'generic.recent_updates' | t }}</h1>
    <p class="mt-2 text-sm text-base-content/70">{{ 'static.recent.subtitle' | t }}</p>
  </header>
  <ul class="divide-y divide-base-300 overflow-hidden rounded-md border border-base-300 bg-base-100">
    {% for p in pages %}
      <li class="px-4 py-3 sm:px-5">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <a href="{{ p.path }}" class="text-base font-medium text-base-content hover:text-primary hover:underline" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ p.link_text }}</a>
            {% if p.settings.tagline != blank %}
              <p class="mt-1 line-clamp-1 text-sm text-base-content/70">{{ p.settings.tagline }}</p>
            {% endif %}
          </div>
          <span class="font-mono text-xs text-base-content/50">{{ p.edited_at | default: p.published_at | date: '%Y-%m-%d' }}</span>
        </div>
      </li>
    {% else %}
      <li class="px-4 py-10 text-center text-sm text-base-content/60">{{ 'generic.empty' | t }}</li>
    {% endfor %}
  </ul>
</div>
