{% assign _become_meta_title = 'partners.become_partner' | t | strip %}
{% set_meta_title _become_meta_title %}
{% assign can_feedback = false %}
{% assign fb_first_emoji = '' %}
{% if site.settings.is_allow_feedback and site.plugins.feedback %}
  {% assign fb_types = site.plugins.feedback.useful_types %}
  {% assign fb_types_size = fb_types | size %}
  {% if fb_types_size > 0 and site.plugins.feedback.message_enabled %}
    {% assign ut0 = fb_types | first %}
    {% assign fb_first_emoji = ut0.emoji %}
    {% assign can_feedback = true %}
  {% endif %}
{% endif %}

<div class="relative z-10 mx-auto max-w-lg px-4 pb-20 pt-8 sm:px-6">
  {% if can_feedback %}
    <div id="js--feedback-{{ page.id }}" class="hidden" aria-hidden="true"></div>
  {% endif %}
  <div
    class="partners-glass-card p-6 sm:p-8"
    x-data="{
      step: 1,
      company: '',
      intent: '',
      email: '',
      phone: '',
      messageDraft: '',
      init() {
        this.$watch('step', (v) => {
          if (v === 4) this.messageDraft = this.summary();
        });
      },
      summary() {
        return [
          '{{ 'partners.form_company' | t }}: ' + this.company,
          '{{ 'partners.form_intent' | t }}: ' + this.intent,
          '{{ 'partners.form_email' | t }}: ' + this.email,
          '{{ 'partners.form_phone' | t }}: ' + this.phone
        ].join('\n');
      },
      goNext() {
        if (this.step === 1 && !this.company.trim()) return;
        if (this.step === 2 && !this.intent.trim()) return;
        if (this.step === 3 && !this.email.trim()) return;
        if (this.step < 4) this.step++;
      }
    }"
  >
    <h1 class="text-2xl font-bold text-slate-900">{{ 'partners.become_partner' | t }}</h1>
    <p class="mt-2 text-sm text-slate-600">{{ 'partners.become_partner_sub' | t }}</p>

    <div class="mt-8 flex gap-2">
      <span class="h-1.5 flex-1 rounded-full transition" :class="step >= 1 ? 'bg-primary' : 'bg-slate-300'"></span>
      <span class="h-1.5 flex-1 rounded-full transition" :class="step >= 2 ? 'bg-primary' : 'bg-slate-300'"></span>
      <span class="h-1.5 flex-1 rounded-full transition" :class="step >= 3 ? 'bg-primary' : 'bg-slate-300'"></span>
      <span class="h-1.5 flex-1 rounded-full transition" :class="step >= 4 ? 'bg-primary' : 'bg-slate-300'"></span>
    </div>

    <div class="mt-8 space-y-5">
      <div x-show="step === 1" class="space-y-3">
        <label class="block text-sm font-medium text-slate-700">{{ 'partners.form_company' | t }}</label>
        <input x-model="company" type="text" class="input input-bordered w-full border-slate-200 bg-white" autocomplete="organization" />
      </div>

      <div x-show="step === 2" class="space-y-3" x-cloak>
        <label class="block text-sm font-medium text-slate-700">{{ 'partners.form_intent' | t }}</label>
        <textarea x-model="intent" rows="4" class="textarea textarea-bordered w-full border-slate-200 bg-white"></textarea>
      </div>

      <div x-show="step === 3" class="space-y-4" x-cloak>
        <div>
          <label class="block text-sm font-medium text-slate-700">{{ 'partners.form_email' | t }}</label>
          <input x-model="email" type="email" class="input input-bordered mt-1 w-full border-slate-200 bg-white" autocomplete="email" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700">{{ 'partners.form_phone' | t }}</label>
          <input x-model="phone" type="tel" class="input input-bordered mt-1 w-full border-slate-200 bg-white" autocomplete="tel" />
        </div>
      </div>

      <div x-show="step === 4" class="space-y-4" x-cloak>
        {% if can_feedback %}
          {% form_tag 'feedback', page: page %}
            <input type="hidden" name="{{ form.feedback_emoji_field_name }}" value="{{ fb_first_emoji | escape_once }}" />
            <fieldset class="fieldset">
              <legend class="fieldset-legend text-sm font-medium text-slate-700">{{ 'snippets.feedback_form.message_label' | t }}</legend>
              <textarea
                name="{{ form.feedback_message_field_name }}"
                x-model="messageDraft"
                rows="8"
                required
                class="textarea textarea-bordered mt-1 w-full min-h-[8rem] border-slate-200 bg-white text-sm leading-relaxed"
                placeholder="{{ 'partners.form_feedback_placeholder' | t }}"
              ></textarea>
              <p class="mt-1 text-xs text-slate-500">{{ 'partners.form_feedback_hint' | t }}</p>
            </fieldset>
            <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:flex-wrap">
              <button type="submit" class="btn btn-primary w-full sm:w-auto sm:flex-1">{{ 'partners.form_submit_feedback' | t }}</button>
            </div>
          {% endform_tag %}
        {% else %}
          <p class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-900">{{ 'partners.form_feedback_unavailable' | t }}</p>
        {% endif %}
      </div>

      <div class="flex justify-between gap-3 pt-2">
        <button type="button" class="btn btn-ghost" x-show="step > 1 && step < 4" x-cloak @click="step--">{{ 'partners.form_back' | t }}</button>
        <span class="flex-1"></span>
        <button type="button" class="btn btn-primary" x-show="step < 4" @click="goNext()">{{ 'partners.form_next' | t }}</button>
      </div>
    </div>
  </div>
</div>
