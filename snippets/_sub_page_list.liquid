{%- comment -%}
  当前页面的下级页面紧凑列表：常嵌在卡片底部。
{%- endcomment -%}
{% assign page_per = per | default: 8 %}
{% assign sub_pages = page.children_in_list | order_by: '-created_at' | limit: page_per %}
{% assign sub_pages_count = page.children_in_list | size %}

{% if sub_pages_count > 0 %}
  <ul class="mt-3 space-y-1 text-sm">
    {% for page in sub_pages %}
      <li>
        <a href="{{ page.path }}" class="flex items-center justify-between gap-2 rounded px-2 py-1 hover:bg-base-200 hover:text-primary">
          <span class="line-clamp-1">{{ page.link_text }}</span>
          <svg class="h-3.5 w-3.5 text-base-content/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </li>
    {% endfor %}
  </ul>
{% endif %}
