{%- comment -%}
  移动端抽屉：Dashboard / Catalog / Downloads / Cases + 文档 / 知识库 + CTA。
{%- endcomment -%}
<div class="drawer drawer-end w-[40px] items-end lg:hidden">
  <input id="header-drawer-right" type="checkbox" class="drawer-toggle" x-init="$el.checked = false;" />
  <div class="drawer-content">
    <label for="header-drawer-right" class="drawer-button inline-flex h-10 w-10 items-center justify-center rounded-full text-base-content hover:bg-base-100/60" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6">
        <path fill-rule="evenodd" d="M3 6.75A.75.75 0 0 1 3.75 6h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 6.75ZM3 12a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 12Zm0 5.25a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
      </svg>
    </label>
  </div>
  <div class="drawer-side z-[60]">
    <label for="header-drawer-right" aria-label="close sidebar" class="drawer-overlay"></label>
    <aside class="min-h-full w-80 border-l border-base-300 bg-base-100 p-5 text-base-content shadow-xl">
      <div class="mb-4 flex items-center justify-between">
        <span class="font-display text-sm font-semibold text-base-content">{{ site.name }}</span>
        <label for="header-drawer-right" class="cursor-pointer text-base-content/50 hover:text-base-content">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </label>
      </div>
      <nav class="flex flex-col gap-1 text-sm font-medium" aria-label="Mobile">
        <a href="{{ index_path }}" class="rounded-full px-3 py-2 hover:bg-base-100/60" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.dashboard' | t }}</a>
        <a href="{{ products_path }}" class="rounded-full px-3 py-2 hover:bg-base-100/60" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.catalog' | t }}</a>
        <a href="{{ downloads_path }}" class="rounded-full px-3 py-2 hover:bg-base-100/60" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.downloads' | t }}</a>
        <a href="{{ cases_path }}" class="rounded-full px-3 py-2 hover:bg-base-100/60" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.cases' | t }}</a>
        <div class="my-2 border-t border-base-200"></div>
        <a href="{{ docs_path }}" class="rounded-full px-3 py-2 text-base-content/70 hover:bg-base-100/60 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.docs' | t }}</a>
        <a href="{{ faqs_path }}" class="rounded-full px-3 py-2 text-base-content/70 hover:bg-base-100/60 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.faqs' | t }}</a>
      </nav>
      <div class="mt-6 space-y-3 border-t border-base-200 pt-5">
        <a href="#lead-dialog" data-lead-trigger class="hub-pill-primary w-full text-center no-underline">{{ site.settings.cta_quote_label | default: 'hub.cta.quote' | t }}</a>
        <a href="{{ site.search_path }}" class="inline-flex w-full items-center justify-center rounded-full border border-base-content py-2.5 text-[13px] font-medium text-base-content no-underline hover:bg-neutral hover:text-neutral-content" data-turbo-frame="main-content-frame" data-turbo-action="advance">
          {{ 'generic.placeholders.search' | t }}
        </a>
      </div>
      {% if site.settings.header_menu_html != blank %}
        <div class="mt-6 space-y-2 border-t border-base-200 pt-5 text-sm text-base-content/70">{{ site.settings.header_menu_html }}</div>
      {% endif %}
    </aside>
  </div>
</div>
