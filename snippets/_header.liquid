{%- comment -%}
  Product Hub top bar (V1, product-only): glass header, brand logo + channel nav,
  search, sign-in / user menu, mobile drawer.
{%- endcomment -%}
{% assign index_path = site.index_path | default: '/' %}
{% assign nav_channels = site.pages['/'].children_in_list | limit: 100 %}
{% assign logo_url = site.settings.logo_url | presence %}
{% assign quote_url = site.settings.cta_quote_url | default: '/s/quote' %}
{% assign quote_label = site.settings.cta_quote_label | default: 'hub.cta.quote' | t %}

<header
  x-data=""
  class="product-hub-glass fixed inset-x-0 top-0 z-50 flex h-[72px] items-center border-b border-base-300/80"
>
  <div class="mx-auto flex h-full w-full max-w-[1280px] items-center justify-between gap-4 px-6">
    <div class="flex min-w-0 items-center gap-2">
      {% assign fallback_logo = 'images/logo.png' | asset_url %}
      <a href="{{ index_path }}" class="flex shrink-0 items-center gap-2" data-turbo-frame="main-content-frame" data-turbo-action="advance">
        {% if logo_url %}
          <img src="{{ logo_url }}" alt="{{ site.name | escape }}" class="h-9 w-auto max-w-[180px] object-contain" />
        {% else %}
          <img src="{{ site.favicon_url | default: fallback_logo }}" alt="" class="h-9 w-9 rounded-lg border border-base-300 bg-base-100 object-contain shadow-sm" onerror="this.style.display='none';" />
          <span class="hidden min-w-0 sm:flex sm:flex-col">
            <span class="font-display text-[20px] font-bold tracking-tight text-base-content">{{ site.name }}</span>
            {% if site.settings.slogan != blank %}
              <span class="font-sans text-[13px] font-normal text-base-content/50">{{ site.settings.slogan }}</span>
            {% endif %}
          </span>
        {% endif %}
      </a>
      <nav class="ml-8 hidden items-center gap-8 text-[14px] font-medium text-base-content/60 md:flex" aria-label="Product Hub">
        {% if site.settings.header_menu_html  %}
          {{ site.settings.header_menu_html }}
        {% else %}
          <a href="{{ index_path }}" class="transition-colors hover:text-base-content" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.dashboard' | t }}</a>
          {% for nav_channel in nav_channels %}
            <a href="{{ nav_channel.path }}" class="transition-colors hover:text-base-content" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ nav_channel.link_text }}</a>
          {% endfor %}
        {% endif %}
      </nav>
    </div>

    <div class="flex items-center gap-4 text-[14px] text-base-content/60">
      <a
        href="{{ site.search_path }}"
        class="hidden items-center gap-2 rounded-lg border border-base-300 bg-base-100 px-4 py-2 text-[13px] shadow-sm transition-colors hover:border-primary/40 hover:text-primary lg:inline-flex"
        data-turbo-frame="main-content-frame"
        data-turbo-action="advance"
        aria-label="{{ 'generic.placeholders.search' | t }}"
      >
        {% render 'icon', name: 'search', class: 'w-4 h-4 text-base-content/50' %}
        <span>{{ 'generic.placeholders.search' | t }}</span>
      </a>
      {% if current_user %}
        <div class="dropdown dropdown-end hidden md:block">
          <div tabindex="0" role="button" aria-haspopup="menu" aria-label="{{ current_user.name | escape }}" class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-base-300 bg-base-100 shadow-sm">
            {% if current_user.image %}
              <img src="{{ current_user.image }}" alt="{{ current_user.name }}" class="h-10 w-10 rounded-full object-cover" />
            {% else %}
              <span class="text-base-content/60">{% render 'icon', name: 'user', class: 'w-5 h-5' %}</span>
            {% endif %}
          </div>
          <div tabindex="0" class="dropdown-content z-[60] mt-2 w-44 space-y-2 rounded-2xl border border-base-300 bg-base-100 p-3 text-sm text-base-content shadow-lg">
            <div class="line-clamp-1 border-b border-base-300 pb-2 font-medium text-base-content">{{ current_user.name }}</div>
            {% form_tag 'sign_out' %}
              <button class="inline-flex w-full items-center gap-2 text-left text-base-content/60 hover:text-primary hover:underline">{% render 'icon', name: 'log-out', class: 'w-4 h-4' %}{{ 'generic.buttons.signout' | t }}</button>
            {% endform_tag %}
          </div>
        </div>
      {% else %}
        <a href="{{ quote_url }}" data-turbo-frame="main-content-frame" data-turbo-action="advance" class="hidden items-center gap-2 rounded-lg bg-primary px-4 py-2 text-[13px] font-medium text-primary-content shadow-sm transition-colors hover:bg-primary/90 no-underline md:inline-flex">
          {% render 'icon', name: 'message-square', class: 'w-4 h-4' %}{{ quote_label }}
        </a>
      {% endif %}
      {% render 'header_drawer', nav_channels: nav_channels, index_path: index_path, quote_url: quote_url, quote_label: quote_label %}
    </div>
  </div>
</header>
<div class="h-[72px]" aria-hidden="true"></div>
