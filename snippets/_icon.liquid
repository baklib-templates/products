{%- comment -%}
  Inline Lucide icon (https://lucide.dev). Renders an inline SVG so icons work
  without JS, avoid hydration flash, and inherit `currentColor`.
  Usage: {% render 'icon', name: 'package', class: 'w-5 h-5' %}
  Params:
    - name  (required): lucide icon name (kebab-case)
    - class (optional): CSS classes for sizing/color, default `w-5 h-5`
    - stroke(optional): stroke-width, default 1.75
{%- endcomment -%}
{%- assign icon_class = class | default: 'w-5 h-5' -%}
{%- assign icon_stroke = stroke | default: 1.75 -%}
{%- capture svg_open -%}<svg xmlns="http://www.w3.org/2000/svg" class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ icon_stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">{%- endcapture -%}
