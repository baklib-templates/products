{%- comment -%}
  Spec groups table (#specs). Scheme A: page.settings.spec_groups is a textarea
  where each line is `Group::Name::Value`. Lines are grouped by the first
  segment into one table per group.
{%- endcomment -%}
{%- assign spec_raw = page.settings.spec_groups | strip -%}
{%- assign spec_lines = spec_raw | newline_to_br | split: '<br />' -%}
{%- assign sep = '~|~' -%}
{%- assign group_keys = sep -%}
{%- assign spec_count = 0 -%}
{%- for line in spec_lines -%}
  {%- assign line = line | strip -%}
  {%- if line == blank -%}{%- continue -%}{%- endif -%}
  {%- assign segs = line | split: '::' -%}
  {%- assign g = segs[0] | strip -%}
  {%- if g == blank -%}{%- continue -%}{%- endif -%}
  {%- assign spec_count = spec_count | plus: 1 -%}
  {%- capture gk -%}{{ sep }}{{ g }}{{ sep }}{%- endcapture -%}
  {%- unless group_keys contains gk -%}
    {%- assign group_keys = group_keys | append: g | append: sep -%}
  {%- endunless -%}
{%- endfor -%}
{%- assign groups = group_keys | split: sep -%}

{% if spec_count > 0 %}
  <section id="specs" class="scroll-mt-28" data-product-section>
    <h2 class="mb-6 flex items-center gap-2 font-display text-2xl font-semibold text-base-content">
      {% render 'icon', name: 'table', class: 'w-6 h-6 text-primary' %}
      {{ 'page.product.specs.title' | t }}
    </h2>
    <div class="space-y-8">
      {% for group in groups %}
        {% assign group = group | strip %}
        {% if group == blank %}{% continue %}{% endif %}
        <div class="overflow-hidden rounded-2xl border border-base-300 bg-base-200">
          <div class="border-b border-base-300 bg-base-300/60 px-5 py-3">
            <h3 class="font-mono text-xs font-semibold uppercase tracking-wide text-base-content/70">{{ group }}</h3>
          </div>
          <table class="w-full border-collapse text-[15px]">
            <tbody>
              {% for line in spec_lines %}
                {% assign line = line | strip %}
                {% if line == blank %}{% continue %}{% endif %}
                {% assign segs = line | split: '::' %}
                {% assign g = segs[0] | strip %}
                {% if g != group %}{% continue %}{% endif %}
                {% assign k = segs[1] | strip %}
                {% assign v = segs[2] | strip %}
                <tr class="border-b border-base-300 transition-colors last:border-0 hover:bg-base-300/50">
                  <td class="w-2/5 px-5 py-3 align-top text-base-content/60">{{ k }}</td>
                  <td class="px-5 py-3 align-top font-medium text-base-content"><span class="font-mono">{{ v }}</span></td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endfor %}
    </div>
  </section>
{% endif %}
