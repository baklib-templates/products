{%- comment -%}
  通用侧栏：搜索 + 频道入口 + 标签云。供 tag / search 等模板复用。
{%- endcomment -%}
{% assign products_path = site.settings.products_root_path | default: '/products' %}
{% assign cases_path = site.settings.cases_root_path | default: '/cases' %}
{% assign docs_path = site.settings.docs_root_path | default: '/docs' %}
{% assign downloads_path = site.settings.downloads_root_path | default: '/downloads' %}
{% assign faqs_path = site.settings.faqs_root_path | default: '/faqs' %}

<div class="space-y-4">
  {% form_tag 'search' %}
    <label class="flex items-center gap-2 rounded-md border border-base-300 bg-base-100 px-3 py-2 text-sm shadow-sm focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20">
      <svg class="h-4 w-4 text-base-content/50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input type="search" class="w-full bg-transparent text-base-content outline-none placeholder:text-base-content/50" name="{{ form.keywords_field_name }}" value="{{ search.keywords | escape }}" placeholder="{{ 'generic.placeholders.search' | t }}" />
    </label>
  {% endform_tag %}

  <nav class="rounded-md border border-base-300 bg-base-100 p-4">
    <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'nav.hub' | t }}</p>
    <ul class="space-y-1 text-sm text-base-content/80">
      <li><a href="{{ products_path }}" class="block rounded px-2 py-1.5 hover:bg-base-200 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.products' | t }}</a></li>
      <li><a href="{{ cases_path }}" class="block rounded px-2 py-1.5 hover:bg-base-200 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.cases' | t }}</a></li>
      <li><a href="{{ docs_path }}" class="block rounded px-2 py-1.5 hover:bg-base-200 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.docs' | t }}</a></li>
      <li><a href="{{ downloads_path }}" class="block rounded px-2 py-1.5 hover:bg-base-200 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.downloads' | t }}</a></li>
      <li><a href="{{ faqs_path }}" class="block rounded px-2 py-1.5 hover:bg-base-200 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ 'nav.faqs' | t }}</a></li>
    </ul>
  </nav>

  {% assign tags_count = site.tags | size %}
  {% if tags_count > 0 %}
    <div class="rounded-md border border-base-300 bg-base-100 p-4">
      <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'generic.all_tags' | t }}</p>
      <ul class="flex flex-wrap gap-2">
        {% for tag in site.tags %}
          <li>
            <a href="{{ tag.path }}" class="inline-flex items-center gap-1.5 rounded-full bg-base-200 px-2.5 py-1 text-xs text-base-content/80 ring-1 ring-base-300 hover:bg-primary/10 hover:text-primary">
              <span class="h-1.5 w-1.5 rounded-full" style="background-color: {{ tag.color }};"></span>
              {{ tag.name }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}
</div>
