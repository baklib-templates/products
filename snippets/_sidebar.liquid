{%- comment -%}
  Shared sidebar for tag / search pages: search box + catalog entry + tag cloud.
{%- endcomment -%}
{% assign index_path = site.index_path | default: '/' %}
{% assign nav_channels = site.pages['/'].children_in_list | limit: 100 %}

<div class="space-y-4">
  {% form_tag 'search' %}
    <label class="flex items-center gap-2 rounded-lg border border-base-300 bg-base-100 px-3 py-2 text-sm shadow-sm focus-within:border-primary">
      <span class="text-base-content/50">{% render 'icon', name: 'search', class: 'w-4 h-4' %}</span>
      <input type="search" class="w-full bg-transparent text-base-content outline-none placeholder:text-base-content/50" name="{{ form.keywords_field_name }}" value="{{ search.keywords | escape }}" placeholder="{{ 'generic.placeholders.search' | t }}" />
    </label>
  {% endform_tag %}

  <nav class="rounded-2xl border border-base-300 bg-base-200 p-4">
    <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'nav.hub' | t }}</p>
    <ul class="space-y-1 text-sm text-base-content/80">
      <li><a href="{{ index_path }}" class="flex items-center gap-2 rounded-lg px-2 py-1.5 hover:bg-base-300 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'icon', name: 'home', class: 'w-4 h-4' %}{{ 'nav.dashboard' | t }}</a></li>
      {% for nav_channel in nav_channels %}
        <li><a href="{{ nav_channel.path }}" class="flex items-center gap-2 rounded-lg px-2 py-1.5 hover:bg-base-300 hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'icon', name: 'boxes', class: 'w-4 h-4' %}{{ nav_channel.link_text }}</a></li>
      {% endfor %}
    </ul>
  </nav>

  {% assign tags_count = site.tags | size %}
  {% if tags_count > 0 %}
    <div class="rounded-2xl border border-base-300 bg-base-200 p-4">
      <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60">{{ 'generic.all_tags' | t }}</p>
      <ul class="flex flex-wrap gap-2">
        {% for tag in site.tags %}
          <li>{% render 'tag', tag: tag %}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}
</div>
