{% if site.settings.is_allow_feedback %}
  <div id="js--feedback-{{ page.id }}" class="flex flex-col items-center justify-center w-full space-y-3 print:hidden">
    {% if page.visitor_posted_feedback %}
      {% assign feedback_label = 'snippets.feedback_button.title_posted' | t %}
    {% else %}
      {% assign feedback_label = 'snippets.feedback_button.title_unposted' | t %}
    {% endif %}
    <a
      data-turbo-stream="true"
      href="{{ page.feedback_path }}"
      aria-label="{{ feedback_label }}"
      class="product-hub-glass-fab flex items-center justify-center border-2 rounded-full cursor-pointer w-14 h-14 transition-all duration-300 hover:-translate-y-2
      {% if page.visitor_posted_feedback %}
      border-primary text-primary bg-primary/10
      {% else %}
      border-base-300 text-base-content/60 hover:border-primary/50 hover:text-primary
      {% endif %}
      "
    >
      {% render 'icon', name: 'thumbs-up', class: 'w-6 h-6' %}
    </a>
    {% if page.visitor_posted_feedback %}
        <span class="w-full text-center text-sm">{{ 'snippets.feedback_button.title_posted' | t}}</span>
    {% else %}
        <span class="w-full text-center text-sm">{{ 'snippets.feedback_button.title_unposted' | t}}</span>
    {% endif %}
  </div>
{% endif %}
