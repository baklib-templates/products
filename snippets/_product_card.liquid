{%- comment -%}
  Product catalog card. Used by the index featured grid and the channel grid.
  Param: page (a product page object).
{%- endcomment -%}
{%- assign cover = page.settings.thumb_image_url | presence -%}
{%- assign model = page.settings.model_code | strip -%}
{%- assign desc = page.settings.description | strip -%}
{%- assign series_label = page.settings.series.label | default: page.settings.series | strip -%}

<article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-base-300 bg-base-100 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md">
  <a
    href="{{ page.path }}"
    class="relative flex aspect-[4/3] items-center justify-center overflow-hidden bg-base-200"
    data-turbo-frame="main-content-frame"
    data-turbo-action="advance"
    aria-label="{{ page.link_text | escape }}"
  >
    {% if cover %}
      <img src="{{ cover }}" alt="{{ page.link_text | escape }}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
    {% else %}
      <span class="text-base-content/30">{% render 'icon', name: 'package', class: 'w-12 h-12' %}</span>
    {% endif %}
    {% if series_label != blank %}
      <span class="absolute left-3 top-3 inline-flex items-center gap-1 rounded-lg bg-base-100/90 px-2.5 py-1 text-[11px] font-medium text-base-content shadow-sm backdrop-blur">
        {% render 'icon', name: 'layers', class: 'w-3.5 h-3.5' %}{{ series_label }}
      </span>
    {% endif %}
  </a>
  <div class="flex flex-1 flex-col p-5">
    {% if model != blank %}
      <p class="mb-1 font-mono text-xs font-medium uppercase tracking-wide text-accent">{{ model }}</p>
    {% endif %}
    <h3 class="font-display text-lg font-semibold leading-snug text-base-content">
      <a href="{{ page.path }}" class="transition-colors hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{{ page.link_text }}</a>
    </h3>
    {% if desc != blank %}
      <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-base-content/70">{{ desc | strip_html | strip }}</p>
    {% endif %}
    <a
      href="{{ page.path }}"
      class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-primary transition-colors hover:gap-2.5"
      data-turbo-frame="main-content-frame"
      data-turbo-action="advance"
    >
      {{ 'channels.products.view_detail' | t }}{% render 'icon', name: 'arrow-right', class: 'w-4 h-4' %}
    </a>
  </div>
</article>
