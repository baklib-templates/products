<a
  href="{{ tag.path }}"
  data-turbo-frame="_top"
  class="inline-flex items-center gap-1.5 rounded-full bg-base-200 px-2.5 py-0.5 text-xs text-base-content/80 ring-1 ring-base-300 hover:bg-primary/10 hover:text-primary"
>
  <span class="h-1.5 w-1.5 rounded-full" style="background-color: {{ tag.color }};"></span>
  {{ tag.name }}
</a>
