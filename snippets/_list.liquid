{% comment %} List rows for index.list — glass card on light shell {% endcomment %}
<article class="partners-glass-card flex justify-between gap-4 border-slate-200/80 px-4 py-4 transition hover:border-primary/40">
  <div class="min-w-0 flex-1">
    <a href="{{ page.path }}" class="flex items-start">
      <div class="mr-3 mt-2 shrink-0">
        <svg class="h-4 w-4 shrink-0 fill-current" viewBox="0 0 16 16">
          <path class="text-primary-darken" d="M4 8H0v4.9c0 1 .7 1.9 1.7 2.1 1.2.2 2.3-.8 2.3-2V8z" />
          <path class="text-primary" d="M15 1H7c-.6 0-1 .4-1 1v11c0 .7-.2 1.4-.6 2H13c1.7 0 3-1.3 3-3V2c0-.6-.4-1-1-1z" />
        </svg>
      </div>
      <h2 class="text-lg font-bold leading-snug text-slate-900 hover:text-primary hover:underline md:text-xl">{{
        page.link_text }}</h2>
    </a>
    <div class="pl-7">
      {% assign desc = page.settings.description | default: page.settings.tagline %}
      {% if desc != blank %}
        <div class="mt-1 text-sm text-slate-600">{{ desc }}</div>
      {% endif %}
      <ul class="mt-2 flex flex-wrap gap-x-2">
        {% for tag in page.tags %}
          <li class="flex items-center text-sm after:px-2 after:text-slate-400 after:content-['·'] last:after:content-['']">
            <a class="font-semibold text-primary hover:underline" href="{{ tag.path }}">{{ tag.name }}</a>
          </li>
        {% endfor %}
      </ul>
      {% render "sub_page_list", page: page, per: 5 %}
    </div>
  </div>
  {% assign page_thumb_image_url = page.settings.thumb_image_url | default: page.settings.logo_image_url | presence %}
  {% if page_thumb_image_url %}
    <div class="shrink-0">
      <img class="max-h-24 rounded-lg ring-1 ring-black/5" src="{{ page_thumb_image_url }}" alt="" loading="lazy" />
    </div>
  {% endif %}
</article>
