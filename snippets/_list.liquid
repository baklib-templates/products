{%- comment -%}
  紧凑行式列表条目：与卡片不同，用于高密度列表。
{%- endcomment -%}
<article class="flex items-start justify-between gap-4 border-b border-base-300 py-4 last:border-b-0">
  <div class="min-w-0 flex-1">
    <h3 class="text-base font-semibold text-base-content sm:text-lg">
      <a href="{{ page.path }}" class="hover:text-primary hover:underline">{{ page.link_text }}</a>
    </h3>
    {% assign desc = page.settings.tagline | default: page.settings.description %}
    {% if desc != blank %}
      <p class="mt-1 line-clamp-2 text-sm text-base-content/70">{{ desc | strip_html | strip }}</p>
    {% endif %}
    <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-base-content/60">
      {% if page.settings.product_model != blank %}
        <span class="font-mono text-base-content/80">{{ page.settings.product_model }}</span>
      {% endif %}
      {% for tag in page.tags %}
        <a href="{{ tag.path }}" class="text-base-content/60 hover:text-primary">#{{ tag.name }}</a>
      {% endfor %}
    </div>
  </div>
  {% assign thumb = page.settings.thumb_image_url | default: page.settings.logo_image_url | presence %}
  {% if thumb %}
    <div class="hidden h-20 w-20 shrink-0 overflow-hidden rounded ring-1 ring-base-300 sm:block">
      <img src="{{ thumb }}" alt="" class="h-full w-full object-cover" loading="lazy" />
    </div>
  {% endif %}
</article>
